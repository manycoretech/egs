{
  "printWidth": 120,
  "tabWidth": 2,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "arrowParens": "avoid",
  "endOfLine": "auto",
  "overrides": [
    {
      "files": "**/*.{ts,js}",
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": "**/*.{md,MD}",
      "options": {
        "tabWidth": 4
      }
    }
  ]
}
