{
  "name": "@internal/egs",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/manycoretech/egs.git"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "type": "module",
  "author": "egs",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "description": "the wrapper repo which contains the egs-main repo and egs-website together to help test and develop",
  "devDependencies": {
    "@internal/cli": "workspace:*",
    "@internal/utils": "workspace:*",
    "@types/node": "^22.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm run --filter=!@internal/* -r build",
    "build:release": "pnpm run --filter=!@internal/* -r build:release"
  }
